# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000

# ── Blockchain (optional — set BLOCKCHAIN_ENABLED=true to activate) ───────────
BLOCKCHAIN_ENABLED=false

# Which network: "sepolia" (Ethereum testnet) or "amoy" (Polygon testnet)
BLOCKCHAIN_NETWORK=sepolia

# Alchemy / Infura RPC URL for your chosen network
# Sepolia: https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# Amoy:    https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY
SEPOLIA_RPC_URL=
AMOY_RPC_URL=

# Private key of the server wallet that was set as contract owner at deploy time
# NEVER commit this value — keep it out of git
DEPLOYER_PRIVATE_KEY=

# Address of the deployed UOWMRewards contract
CONTRACT_ADDRESS=
