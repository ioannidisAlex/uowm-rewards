AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY

# ── Block explorer verification (optional) ────────────────────────────────────
ETHERSCAN_API_KEY=
POLYGONSCAN_API_KEY=
